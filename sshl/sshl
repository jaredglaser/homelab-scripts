#!/usr/bin/env bash
set -euo pipefail

SSHL_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"

rebuild=false
for arg in "$@"; do
    case "$arg" in
        -R|--rebuild) rebuild=true ;;
        -h|--help)
            cat <<EOF
Usage: $(basename "$0") [options]
  -R, --rebuild    Nuke the tmux server and rebuild windows from cache.
  -h, --help       Show this help.

With no flags: bootstrap a new session (scan + filter on first run) or
attach a grouped view to the existing session.

Inside the session, use these key bindings to manage hosts:
  prefix S    Scan + add or remove hosts (popup)
  prefix O    Reorder windows (popup)
  prefix I    Show ignored hosts to un-ignore (popup)
  prefix H    Fuzzy jump to a host
EOF
            exit 0 ;;
        *) echo "Unknown argument: $arg" >&2; exit 1 ;;
    esac
done

source "$(dirname "${BASH_SOURCE[0]}")/sshl-lib.sh"

read_cache
read_ignored

built=false
if $rebuild; then
    if [[ ${#ips[@]} -eq 0 ]]; then
        echo "Error: no cache to rebuild from. Run sshl with no args to bootstrap." >&2
        exit 1
    fi
    build_session
    built=true
elif ! session_is_healthy; then
    if [[ ${#ips[@]} -eq 0 ]]; then
        # First-run bootstrap: scan, run filter popup in current shell,
        # then build session from selection.
        echo "No cached hosts. Running scan + filter to bootstrap..." >&2
        "${SSHL_DIR}/popup-scan.sh"
        read_cache
        # popup-scan.sh already printed why nothing was applied (cancelled,
        # nothing to show, no selection, write failure). Exit quietly
        # rather than tacking on a generic catch-all message.
        if [[ ${#ips[@]} -eq 0 ]]; then
            exit 0
        fi
        build_session
        built=true
    else
        build_session
        built=true
    fi
fi

# Warm host-info cache so window switches hit a fresh entry. The
# 24h TTL in host-info.sh means most calls return cached data,
# but cold-cache entries SSH the host and run apt-get update.
# Backgrounding lets the user attach without waiting on those.
echo "Warming host-info cache for ${#ips[@]} host(s) in background..." >&2
for ip in "${ips[@]}"; do
    u="${host_user[$ip]:-$default_user}"
    "$INFO_SCRIPT" "$u" "$ip" >/dev/null 2>&1 &
done
disown -a 2>/dev/null || true

# Reload conf so edits to homelab.tmux.conf take effect without --rebuild.
"${TMUX_CMD[@]}" source-file "$TMUX_CONF" 2>/dev/null || true

# Refresh the global env each run. New popups spawn fresh shells that
# inherit this env, so the popup bindings find $SSHL_DIR / $SSHL_BIN
# even on sessions built by an older sshl that never set them.
session_exists && set_session_env

$built || echo "Reusing existing session '$session_name' (use --rebuild to recreate)."

# Grouped attach: a new session sharing the base session's windows but
# with its own focus. destroy-unattached cleans up when the konsole
# closes.
attach_cmd=("${TMUX_CMD[@]}" new-session -t "$session_name" \;
            set-option destroy-unattached on)

if [[ -n "${TMUX:-}" ]]; then
    echo "Already inside a tmux session (different server)."
    echo "Run from a fresh terminal, or: tmux -L $SOCKET new-session -t $session_name"
elif command -v "$terminal" &>/dev/null; then
    "$terminal" -e "${attach_cmd[@]}" &
    disown
else
    echo "Terminal '$terminal' not found; attaching in current shell." >&2
    "${attach_cmd[@]}"
fi
